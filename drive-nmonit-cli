# =============================================================================
# Command-line mode
# =============================================================================

cli_mode() {
    local cmd="${1:-}"
    shift 2>/dev/null || true

    case "$cmd" in
        status|info)
            if [[ "${1:-}" == "--json" ]]; then
                show_status_json
            else
                show_status
            fi
            ;;
        health)
            require_root
            run_health_check "$@"
            ;;
        install)
            require_root
            run_install
            ;;
        setup-mergerfs|pool)
            require_root
            run_setup_mergerfs
            ;;
        setup-gluster|gluster-init)
            require_root
            if [[ "${1:-}" == "--join" ]]; then
                run_gluster_join
            else
                run_gluster_init
            fi
            ;;
        gluster-join|join)
            require_root
            run_gluster_join
            ;;
        mount)
            require_root
            run_mount
            ;;
        tune|tuning)
            require_root
            run_tuning
            ;;
        samba)
            require_root
            run_samba
            ;;
        nfs)
            require_root
            run_nfs
            ;;
        dashboard|web)
            require_root
            run_dashboard
            ;;
        logs)
            run_logs
            ;;
        system-info|sysinfo)
            run_system_info
            ;;
        init-config)
            run_init_config
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            echo "Unknown command: $cmd"
            echo "Usage: $0 [command]"
            echo "Run '$0 help' for a full command reference."
            exit 1
            ;;
    esac
}

# =============================================================================
# Main entry point
# =============================================================================

# Trap Ctrl+C for clean exit
trap 'echo -e "${SHOW_CURSOR}"; exit 0' INT TERM

# --- Config file loading (two-pass: first extract --config, then load config, then parse remaining flags) ---

# First pass: extract --config from args (before loading config so CLI can override)
SKIP_NEXT=false
for arg in "$@"; do
    if [[ "$SKIP_NEXT" == true ]]; then
        CUSTOM_CONFIG="$arg"
        SKIP_NEXT=false
        continue
    fi
    case "$arg" in
        --config=*)
            CUSTOM_CONFIG="${arg#*=}"
            ;;
        --config)
            SKIP_NEXT=true
            ;;
    esac
done

# Load config file (lowest priority — CLI flags below will override)
if [[ -n "$CUSTOM_CONFIG" ]]; then
    if [[ -f "$CUSTOM_CONFIG" ]]; then
        # shellcheck disable=SC1090
        source "$CUSTOM_CONFIG" 2>/dev/null || true
    fi
elif [[ -f "$DEFAULT_CONFIG" ]]; then
    # shellcheck disable=SC1091
    source "$DEFAULT_CONFIG" 2>/dev/null || true
fi

# Validate config values — warnings for invalid keys, resets to defaults
validate_config

# Second pass: parse CLI args (highest priority — overrides config values)
CLI_ARGS=()
SKIP_NEXT=false
for arg in "$@"; do
    if [[ "$SKIP_NEXT" == true ]]; then
        SKIP_NEXT=false
        continue
    fi
    case "$arg" in
        --config=*) ;;
        --config)  SKIP_NEXT=true ;;
        --dry-run) DRY_RUN=true ;;
        --no-dry-run) DRY_RUN=false ;;
        --yes|--confirm|-y) YES_MODE=true ;;
        *) CLI_ARGS+=("$arg") ;;
    esac
done

set -- "${CLI_ARGS[@]}"

# Root check (most operations need root)
require_root

print_dry_run_banner
print_yes_banner

# Create config directory
ensure_dir "$CONFIG_DIR" 2>/dev/null || true

# First-run welcome
if [[ ! -f "${CONFIG_DIR}/.first-run" ]]; then
    echo ""
    print_box_header "Welcome to drive-nmonit v${VERSION}" 60
    echo ""
    echo "  This CLI manages your unified network-distributed storage."
    echo "  It orchestrates all setup scripts through an interactive menu."
    echo ""
    echo "  Quick start:"
    echo "    1. Install Dependencies"
    echo "    2. Setup Local Pool (on ALL nodes)"
    echo "    3. Init Cluster (on primary node)"
    echo "    4. Join Cluster (on slave nodes)"
    echo "    5. Mount Workspace (on ALL nodes)"
    echo ""
    echo "  Each step is described in the README.md"
    echo ""
    print_box_footer 60
    echo ""
    touch "${CONFIG_DIR}/.first-run"
    _pause
fi

# Detect state once on startup
detect_state

# CLI or interactive mode?
if [[ $# -gt 0 ]]; then
    cli_mode "$@"
else
    while true; do
        show_main_menu
    done
fi
