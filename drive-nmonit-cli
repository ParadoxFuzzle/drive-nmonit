# =============================================================================
# Init config
# =============================================================================

run_init_config() {
    echo ""
    print_box_header "Initialize Persistent Configuration" 62
    echo ""
    echo "  This will create a config file at ${DEFAULT_CONFIG}"
    echo "  with the settings you choose. Default flags stored here"
    echo "  apply every time you run drive-nmonit-cli."
    echo ""

    local config_dir="$(dirname "$DEFAULT_CONFIG")"
    ensure_dir "$config_dir"

    # Check if config already exists
    if [[ -f "$DEFAULT_CONFIG" ]] && ! _confirm "Config already exists. Overwrite?" "N"; then
        print_info "Config initialization cancelled."
        _pause
        return
    fi

    # Prompt for settings
    local opt_dry_run=""
    local opt_yes_mode=""

    if [[ "$YES_MODE" == true ]]; then
        # Auto-confirm — use defaults (both disabled)
        opt_dry_run="false"
        opt_yes_mode="false"
    else
        echo "  ── Settings ──"
        echo ""

        echo "  Dry-run mode: preview commands without executing them."
        read -r -p "  Enable? [y/N]: " reply
        if [[ "${reply,,}" == "y" ]]; then
            opt_dry_run="true"
        else
            opt_dry_run="false"
        fi

        echo ""
        echo "  Auto-confirm mode: automatically answer all prompts"
        echo "  with their defaults (skips 'Press Enter' pauses)."
        read -r -p "  Enable? [y/N]: " reply
        if [[ "${reply,,}" == "y" ]]; then
            opt_yes_mode="true"
        else
            opt_yes_mode="false"
        fi
    fi

    # Preview
    echo ""
    echo "  ── Config Preview ──"
    echo ""
    echo "  Path: ${DEFAULT_CONFIG}"
    echo "  DRY_RUN=${opt_dry_run}"
    echo "  YES_MODE=${opt_yes_mode}"
    echo ""

    if [[ "$DRY_RUN" == true ]]; then
        echo -e "  ${YELLOW}[DRY-RUN]${NC} Config file would be written — skipping."
        echo ""
        _pause
        return
    fi

    if ! _confirm "Write config file?" "Y"; then
        print_info "Config initialization cancelled."
        _pause
        return
    fi

    # Write the config file
    cat > "$DEFAULT_CONFIG" <<-CONFIGEOF
# =============================================================================
# drive-nmonit — Persistent Configuration File
# =============================================================================
# This file was generated by 'drive-nmonit-cli init-config'.
# Valid values for each key are true/false (lowercase only).
# Command-line flags override these values.
# =============================================================================

# Preview commands without executing them (--dry-run)
DRY_RUN=${opt_dry_run}

# Auto-answer prompts with defaults (--yes / --confirm / -y)
YES_MODE=${opt_yes_mode}
CONFIGEOF

    echo ""
    print_success "Config written to ${DEFAULT_CONFIG}"
    print_info "Edit with: sudo nano ${DEFAULT_CONFIG}"
    echo ""

    # Reload config so it takes effect immediately
    # shellcheck disable=SC1091
    source "$DEFAULT_CONFIG" 2>/dev/null || true
    validate_config

    _pause
}

